{
  "name": "@trimble-oss/moduswebcomponents-vue",
  "version": "0.0.1",
  "description": "Trimble Modus Vue Component Library",
  "license": "MIT",
  "author": "Trimble Inc.",
  "type": "module",
  "files": [
    "**/*"
  ],
  "dependencies": {
    "@stencil/vue-output-target": "^0.10.8"
  },
  "peerDependencies": {
    "@trimble-oss/moduswebcomponents": "0.0.0-alpha.1",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "copyfiles": "^2.4.1",
    "rimraf": "^6.0.1",
    "symlink-dir": "^6.0.3",
    "typescript": "^5.6.3"
  },
  "main": "./index.js",
  "module": "./index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./types/index.d.ts"
    }
  },
  "scripts": {
    "prebuild": "npm run symlink",
    "build": "npm run clean && npm run transpile && npm run copy-types && npm run copy-meta",
    "clean": "rimraf dist",
    "transpile": "tsc -p . --noEmitOnError false || true",
    "copy-types": "tsc -p . --declaration --emitDeclarationOnly --outDir dist/types || true",
    "symlink": "symlink-dir ../stencil-generated/ src/stencil-generated/",
    "copy-meta": "copyfiles -f README.md package.json LICENSE dist"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
} 