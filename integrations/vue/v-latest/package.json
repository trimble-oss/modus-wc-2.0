{
  "name": "@trimble-oss/moduswebcomponents-vue",
  "version": "0.0.1",
  "description": "Trimble Modus Vue Component Library",
  "license": "MIT",
  "author": "Trimble Inc.",
  "files": [
    "dist",
    "types"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "dependencies": {
    "@stencil/vue-output-target": "^0.7.4"
  },
  "peerDependencies": {
    "@trimble-oss/moduswebcomponents": "0.0.0-alpha.1",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@trimble-oss/moduswebcomponents": "0.0.0-alpha.1",
    "copyfiles": "^2.4.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  },
  "scripts": {
    "build": "npm run clean && npm run tsc && npm run copy-generated && npm run copy-meta",
    "clean": "rimraf dist",
    "tsc": "tsc -p .",
    "copy-generated": "copyfiles -u 1 'src/components.ts' dist",
    "copy-meta": "copyfiles -f README.md package.json LICENSE dist"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
} 