{
  "name": "@trimble-oss/moduswebcomponents-react",
  "version": "0.0.1-react19",
  "description": "Trimble Modus React Component Library",
  "license": "MIT",
  "author": "Trimble Inc.",
  "dependencies": {
    "@stencil/react-output-target": "^0.7.4",
    "@trimble-oss/moduswebcomponents": "0.0.0-alpha.1"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "symlink-dir": "^6.0.3",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "npm run symlink",
    "build": "npm run clean && npm run tsc",
    "clean": "rimraf dist",
    "tsc": "tsc -p . --outDir ./dist",
    "symlink": "symlink-dir ../stencil-generated/ src/stencil-generated/"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
