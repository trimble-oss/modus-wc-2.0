{
  "name": "@trimble-oss/moduswebcomponents-react",
  "version": "0.0.1-react19",
  "description": "Trimble Modus React Component Library",
  "license": "MIT",
  "author": "Trimble Inc.",
  "dependencies": {
    "@stencil/react-output-target": "^0.7.4",
    "@trimble-oss/moduswebcomponents": "file:../../../dist"
  },
  "devDependencies": {
    "copyfiles": "^2.4.1",
    "rimraf": "^6.0.1",
    "symlink-dir": "^6.0.3",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "react": "^19.0",
    "react-dom": "^19.0"
  },
  "main": "index-cjs.js",
  "module": "index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./index.js",
      "require": "./index-cjs.js",
      "default": "./index.js"
    },
    "./modus-wc-styles.css": "./modus-wc-styles.css"
  },
  "scripts": {
    "prebuild": "npm run symlink",
    "build": "npm run clean && npm run tsc && npm run copy-css && npm run copy-assets && npm run copy-meta",
    "clean": "rimraf dist",
    "tsc": "tsc -p . --outDir ./dist",
    "symlink": "symlink-dir ../stencil-generated/ src/stencil-generated/",
    "copy-css": "copyfiles -f node_modules/@trimble-oss/moduswebcomponents/modus-wc-styles.css dist",
    "copy-assets": "copyfiles -u 3 'node_modules/@trimble-oss/moduswebcomponents/assets/**/*' dist",
    "copy-meta": "copyfiles -f README.md package.json dist"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
