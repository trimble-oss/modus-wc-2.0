{
	"name": "test-react-v18",
	"private": true,
	"version": "0.0.1",
	"description": "Test application for Modus React Component Library for React v18",
	"type": "module",
	"scripts": {
		"start": "vite --open",
		"build": "tsc -b && vite build",
		"lint": "npm run lint:eslint",
		"lint:eslint": "eslint --cache --cache-location .eslintcache .",
		"format": "npm run format:eslint",
		"format:eslint": "eslint --cache --cache-location .eslintcache --fix .",
		"preview": "npm run build && vite preview --open"
	},
	"dependencies": {
		"@trimble-oss/moduswebcomponents-react": "file:../v18/trimble-oss-moduswebcomponents-react-0.0.1-react18.tgz",
		"react": "^18.3",
		"react-dom": "^18.3"
	},
	"devDependencies": {
		"@eslint/js": "^9.13.0",
		"@types/react": "^18.3",
		"@types/react-dom": "^18.3",
		"@vitejs/plugin-react": "^4.3.3",
		"eslint": "^9.15",
		"eslint-plugin-react-hooks": "^5.0.0",
		"eslint-plugin-react-refresh": "^0.4.14",
		"globals": "^15.12",
		"typescript": "~5.6.3",
		"typescript-eslint": "^8.15",
		"vite": "^5.4"
	}
}
