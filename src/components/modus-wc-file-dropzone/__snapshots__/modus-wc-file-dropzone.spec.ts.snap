exports[`modus-wc-file-dropzone should render with disabled prop 1`] = `
<modus-wc-file-dropzone disabled="">
  <!---->
  <div class="modus-wc-file-dropzone">
    <input class="file-input file-input-disabled modus-wc-file-input" disabled="" type="file">
    <div aria-disabled="true" aria-label="Upload files" class="dropzone-content" role="button" tabindex="-1">
      <div class="default-content">
        <modus-wc-icon class="upload-icon" name="cloud_upload" size="lg" variant="solid"></modus-wc-icon>
