// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`modus-wc-app-menu should render with custom class 1`] = `
<modus-wc-app-menu class="my-custom-class">
  <!---->
  <modus-wc-panel height="568px" width="320px">
    <div slot="body">
      <div class="menu-header">
        <div class="header-title">
          <modus-wc-typography label="Trimble apps" size="md" weight="bold"></modus-wc-typography>
        </div>
        <div class="header-end-content">
          <modus-wc-button aria-label="Edit app order" color="tertiary" shape="square" size="sm" variant="filled">
            <modus-wc-icon name="pencil"></modus-wc-icon>
          </modus-wc-button>
        </div>
      </div>
      <div class="app-menu-body">
        <div aria-label="Construction" class="app-menu-section" role="group">
          <div class="submenu-title-container">
            <modus-wc-typography label="Construction" size="md" weight="bold"></modus-wc-typography>
            <modus-wc-typography label="Project management tools" size="sm" weight="normal"></modus-wc-typography>
          </div>
          <div class="app-menu-items">
            <modus-wc-menu>
              <div class="app-menu-item-row" draggable="false">
                <modus-wc-menu-item label="Trimble Connect">
                  <modus-wc-logo custom-class="app-logo" emblem="" name="connect" slot="start-icon"></modus-wc-logo>
                </modus-wc-menu-item>
              </div>
              <div class="app-menu-item-row" draggable="false">
                <modus-wc-menu-item label="Viewpoint">
                  <modus-wc-logo custom-class="app-logo" emblem="" name="viewpoint" slot="start-icon"></modus-wc-logo>
                </modus-wc-menu-item>
              </div>
            </modus-wc-menu>
          </div>
        </div>
        <div aria-label="Design" class="app-menu-section" role="group">
          <div class="submenu-title-container">
            <modus-wc-typography label="Design" size="md" weight="bold"></modus-wc-typography>
            <modus-wc-typography label="Design tools" size="sm" weight="normal"></modus-wc-typography>
          </div>
          <div class="app-menu-items">
            <modus-wc-menu>
              <div class="app-menu-item-row" draggable="false">
                <modus-wc-menu-item label="SketchUp">
                  <modus-wc-logo custom-class="app-logo" emblem="" name="sketchup" slot="start-icon"></modus-wc-logo>
                </modus-wc-menu-item>
              </div>
              <div class="app-menu-item-row" draggable="false">
                <modus-wc-menu-item label="Tekla">
                  <modus-wc-logo custom-class="app-logo" emblem="" name="tekla" slot="start-icon"></modus-wc-logo>
                </modus-wc-menu-item>
              </div>
            </modus-wc-menu>
          </div>
        </div>
      </div>
    </div>
  </modus-wc-panel>
</modus-wc-app-menu>
`;

