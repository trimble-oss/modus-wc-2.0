              <modus-wc-avatar alt="" size="xs"></modus-wc-avatar>
            </button>
          </modus-wc-button>
          <div class="hidden user">
            <modus-wc-card>
              <div slot="header">
                <modus-wc-avatar alt=""></modus-wc-avatar>
              </div>
              <div slot="title"></div>
              <div></div>
              <div slot="actions">
