                    Access MyTrimble
                  </button>
                </modus-wc-button>
              </div>
              <div slot="footer">
                <modus-wc-button>
                  <!---->
                  <button class="modus-wc-btn modus-wc-btn-borderless modus-wc-btn-md modus-wc-btn-primary sign-out" tabindex="0" type="button">
                    Sign out
                  </button>
                </modus-wc-button>
              </div>
            </modus-wc-card>
          </div>
        </div>
      </div>
    </div>
