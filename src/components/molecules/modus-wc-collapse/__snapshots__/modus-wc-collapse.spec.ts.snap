exports[`modus-wc-collapse should render with custom props 1`] = `
<modus-wc-collapse bordered="false" collapse-description="Test description" collapse-title="Test title" custom-class="test-class" expanded="true" icon="alert" icon-aria-label="Alert icon">
  <!---->
  <div class="modus-wc-collapse modus-wc-collapse-arrow modus-wc-collapse-open test-class">
    <input aria-controls="test-title-content" aria-expanded="" aria-labelledby="test-title-title" id="test-title-checkbox" role="button" type="checkbox">
    <div class="modus-wc-collapse-title modus-wc-inline-flex modus-wc-items-center modus-wc-justify-between" id="test-title-title">
      <div class="modus-wc-font-medium modus-wc-inline-flex modus-wc-items-center modus-wc-text-xl">
        <modus-wc-icon aria-label="Alert icon">
          <i aria-hidden="true" class="modus-icons modus-wc-icon--md" tabindex="-1">
            alert
          </i>
        </modus-wc-icon>
        Test title
      </div>
      <div class="modus-wc-font-light">
        Test description
      </div>
    </div>
    <div aria-labelledby="test-title-title" class="modus-wc-collapse-content modus-wc-cursor-default" id="test-title-content"></div>
  </div>
</modus-wc-collapse>
`;

