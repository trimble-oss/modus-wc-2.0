exports[`modus-wc-collapse should render in expanded state 1`] = `
<modus-wc-collapse collapse-title="Expanded" expanded="true">
  <!---->
  <div class="modus-wc-border modus-wc-collapse modus-wc-collapse-arrow modus-wc-collapse-open">
    <input aria-controls="expanded-content" aria-expanded="" aria-labelledby="expanded-title" id="expanded-checkbox" role="button" type="checkbox">
    <div class="modus-wc-collapse-title modus-wc-inline-flex modus-wc-items-center modus-wc-justify-between" id="expanded-title">
      <div class="modus-wc-font-medium modus-wc-inline-flex modus-wc-items-center modus-wc-text-xl">
        Expanded
      </div>
    </div>
    <div aria-labelledby="expanded-title" class="modus-wc-collapse-content modus-wc-cursor-default" id="expanded-content">
      <div>
        Expanded Content
      </div>
    </div>
  </div>
</modus-wc-collapse>
`;

