exports[`modus-wc-chip should render with image avatar when imageUrl is provided 1`] = `
<modus-wc-chip aria-label="Chip with avatar" image-url="test.jpg">
  <!---->
  <button aria-label="chip" class="modus-wc-btn modus-wc-btn-md modus-wc-chip" tabindex="0" type="button">
    <modus-wc-avatar alt="chip" aria-label="chip" class="modus-wc-chip-avatar-container" custom-class="modus-wc-chip-avatar false" img-src="test.jpg"></modus-wc-avatar>
