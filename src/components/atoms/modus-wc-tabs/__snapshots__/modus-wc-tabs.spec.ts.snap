exports[`modus-wc-tabs should render with custom props 1`] = `
<modus-wc-tabs aria-label="Custom Tab Group" custom-class="test-class" size="sm" tab-style="boxed" tabs="[{&quot;id&quot;:&quot;tab1&quot;,&quot;label&quot;:&quot;Tab 1&quot;,&quot;active&quot;:true},{&quot;id&quot;:&quot;tab2&quot;,&quot;label&quot;:&quot;Tab 2&quot;},{&quot;id&quot;:&quot;tab3&quot;,&quot;label&quot;:&quot;Tab 3&quot;,&quot;disabled&quot;:true},{&quot;id&quot;:&quot;tab4&quot;,&quot;icon&quot;:&quot;home&quot;}]">
  <!---->
  <div aria-label="Tab Group" class="modus-wc-tabs modus-wc-tabs-boxed modus-wc-tabs-sm test-class" role="tablist"></div>
  <div role="tabpanel" tabindex="0">
  </div>
</modus-wc-tabs>
`;

exports[`modus-wc-tabs should render with default props 1`] = `
