{
  "name": "@trimble-cms/modus-wc",
  "version": "0.0.1",
  "description": "Modus Web Components using Stencil",
  "keywords": [],
  "license": "MIT",
  "author": "Trimble Inc.",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.js",
  "es2017": "dist/esm/index.js",
  "esnext": "dist/esm/index.js",
  "jsnext:main": "dist/esm/index.js",
  "types": "dist/types/components.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/modus-wc/modus-wc.esm.js",
  "jsdelivr": "dist/modus-wc/modus-wc.js",
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "wireit",
    "build:stencil": "wireit",
    "dev": "concurrently \"npm run stencil:dev\" \"storybook dev -p 6006\"",
    "lint": "wireit",
    "lint:eslint": "wireit",
    "lint:fix": "wireit lint:eslint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "concurrently \"npm run tailwind:watch\" \"stencil build --dev --watch --serve\"",
    "test": "stencil test --spec --e2e",
    "test:coverage": "stencil test --spec --coverage",
    "test:update-snapshot": "stencil test --spec --e2e --update-snapshot",
    "test:watch": "stencil test --spec --e2e --watchAll",
    "stencil:dev": "stencil build --dev --docs --watch",
    "stencil:build": "stencil build --docs",
    "stencil:watch": "stencil build --dev --watch",
    "storybook": "wireit",
    "storybook:build": "wireit",
    "tailwind": "wireit"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.10.3",
    "@eslint/js": "^9.11.1",
    "@stencil/angular-output-target": "^0.9.1",
    "@stencil/core": "^4.22.0",
    "@stencil/react-output-target": "^0.7.4",
    "@stencil/sass": "^3.0.12",
    "@stencil/store": "^2.0.16",
    "@storybook/addon-a11y": "^8.4.2",
    "@storybook/addon-essentials": "^8.4.2",
    "@storybook/addon-links": "^8.4.2",
    "@storybook/addon-themes": "^8.4.2",
    "@storybook/blocks": "^8.4.2",
    "@storybook/test": "^8.4.2",
    "@storybook/web-components": "^8.4.2",
    "@storybook/web-components-vite": "^8.4.2",
    "@tailwindcss/typography": "^0.5.15",
    "@types/jest": "^29.5.13",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "concurrently": "^9.0.1",
    "daisyui": "^4.12.13",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.10.0",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "marked": "^14.1.2",
    "prettier": "^3.3.3",
    "puppeteer": "^23.5.3",
    "stencil-tailwind-plugin": "^1.8.0",
    "tailwindcss": "^3.4.14",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.2",
    "wireit": "^0.14.9"
  },
  "wireit": {
    "build": {
      "dependencies": [
        "tailwind",
        "build:stencil"
      ]
    },
    "build:custom-elements-json": {
      "command": "custom-elements-manifest analyze --stencil --globs \"src/components/**/*.tsx\" --outdir src && node .github/fixup-cem-json.cjs",
      "files": [
        "src/components/**/*.tsx"
      ],
      "output": [
        "src/custom-elements.json"
      ]
    },
    "build:stencil": {
      "command": "stencil build --docs --ts",
      "dependencies": [
        "build:custom-elements-json"
      ],
      "files": [
        "src/**/*.{.css,.scss,.ts,.tsx}",
        "src/custom-elements.json",
        "!src/components.d.ts",
        "stencil.config.ts",
        "tsconfig.json"
      ],
      "output": [
        "src/components.d.ts",
        "dist/",
        "loader/",
        "integrations/react/stencil-generated/",
        "integrations/angular/ng18/projects/trimble-cms/modus-wc-ng/src/lib/stencil-generated/"
      ]
    },
    "lint": {
      "dependencies": [
        "lint:eslint",
        "format:check"
      ]
    },
    "lint:eslint": {
      "command": "eslint --color --cache --cache-location .eslintcache .",
      "files": [
        "src/**/*.{ts,tsx,js,jsx}",
        "eslint.config.js"
      ]
    },
    "lint:eslint:fix": {
      "command": "eslint --color --cache --cache-location .eslintcache --fix .",
      "files": [
        "src/**/*.{ts,tsx,js,jsx}",
        "eslint.config.js"
      ]
    },
    "storybook": {
      "command": "storybook dev -p 6006",
      "dependencies": [
        "build"
      ],
      "files": [
        "src/",
        ".storybook",
        "dist/",
        "loader/",
        "stencil.config.ts"
      ],
      "service": true
    },
    "storybook:build": {
      "command": "storybook build",
      "clean": false,
      "dependencies": [
        "build"
      ],
      "files": [
        "src/",
        ".storybook",
        "dist/",
        "loader/",
        "stencil.config.ts"
      ],
      "output": [
        "storybook-static/"
      ]
    },
    "tailwind": {
      "command": "tailwindcss -i src/styles/tailwind.css -o src/styles/output.css -m",
      "files": [
        "src/styles/tailwind.css",
        "tailwind.config.js"
      ],
      "output": [
        "src/styles/output.css"
      ]
    }
  }
}
