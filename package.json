{
  "name": "@trimble-cms/modus-wc",
  "version": "0.0.1",
  "description": "Modus Web Components using Stencil",
  "keywords": [],
  "license": "MIT",
  "author": "Trimble Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Trimble-Construction/poc-modus-wc-2.0.git"
  },
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.js",
  "es2017": "dist/esm/index.js",
  "esnext": "dist/esm/index.js",
  "jsnext:main": "dist/esm/index.js",
  "types": "dist/types/components.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/modus-wc/modus-wc.esm.js",
  "jsdelivr": "dist/modus-wc/modus-wc.js",
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "wireit",
    "build:ci": "wireit",
    "clean": "npx rimraf .wireit .stencil .eslintcache .storybook-static dist loader",
    "lint": "wireit",
    "lint:eslint": "wireit",
    "lint:prettier": "wireit",
    "format": "wireit",
    "start": "wireit",
    "test": "stencil test --spec",
    "test:coverage": "stencil test --spec --coverage",
    "test:update-snapshot": "stencil test --spec --update-snapshot",
    "test:watch": "stencil test --spec --watchAll"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.10.3",
    "@eslint/js": "^9.11.1",
    "@stencil/angular-output-target": "^0.9.1",
    "@stencil/core": "^4.22.0",
    "@stencil/react-output-target": "^0.7.4",
    "@stencil/sass": "^3.0.12",
    "@stencil/store": "^2.0.16",
    "@storybook/addon-a11y": "^8.4.2",
    "@storybook/addon-essentials": "^8.4.2",
    "@storybook/addon-links": "^8.4.2",
    "@storybook/addon-themes": "^8.4.2",
    "@storybook/blocks": "^8.4.2",
    "@storybook/test": "^8.4.2",
    "@storybook/web-components": "^8.4.2",
    "@storybook/web-components-vite": "^8.4.2",
    "@tailwindcss/typography": "^0.5.15",
    "@types/jest": "^29.5.13",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "concurrently": "^9.0.1",
    "daisyui": "^4.12.13",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.10.0",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "marked": "^14.1.2",
    "prettier": "^3.3.3",
    "puppeteer": "^23.5.3",
    "stencil-tailwind-plugin": "^1.8.0",
    "tailwindcss": "^3.4.14",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.2",
    "wireit": "^0.14.9"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.9.5"
  },
  "wireit": {
    "build": {
      "dependencies": [
        "stencil:build",
        "storybook:build",
        "lint"
      ]
    },
    "build:cem-json": {
      "command": "custom-elements-manifest analyze --stencil --globs \"src/components/**/*.tsx\" --outdir src && node .github/fixup-cem-json.cjs",
      "files": [
        "src/components/**/*.tsx"
      ],
      "output": [
        "src/custom-elements.json"
      ]
    },
    "build:ci": {
      "dependencies": [
        "stencil:build"
      ]
    },
    "format": {
      "dependencies": [
        "format:prettier",
        "format:eslint"
      ]
    },
    "format:eslint": {
      "command": "eslint --color --cache --cache-location .eslintcache --fix .",
      "files": [
        "src/**/*.{ts,tsx,js,jsx}",
        "eslint.config.js"
      ]
    },
    "format:prettier": {
      "command": "prettier --write .",
      "files": [
        "*.{ts,tsx,js,jsx,css,scss,json,md,mdx,html}",
        "!src/components.d.ts"
      ]
    },
    "lint": {
      "dependencies": [
        "lint:eslint",
        "lint:prettier"
      ]
    },
    "lint:eslint": {
      "command": "eslint --color --cache --cache-location .eslintcache .",
      "clean": false,
      "files": [
        "src/**/*.{ts,tsx,js,jsx}",
        "!src/components.d.ts",
        "eslint.config.js"
      ],
      "output": [
        "src/**/*.{ts,tsx,js,jsx}",
        "!src/components.d.ts",
        ".eslintcache"
      ]
    },
    "lint:prettier": {
      "command": "prettier --check .",
      "clean": false,
      "files": [
        "*.{ts,tsx,js,jsx,css,scss,json,md,mdx,html}",
        "!src/components.d.ts"
      ],
      "output": [
        "*.{ts,tsx,js,jsx,css,scss,json,md,mdx,html}",
        "!src/components.d.ts"
      ]
    },
    "start": {
      "dependencies": [
        "storybook:start",
        "lint"
      ]
    },
    "stencil:build": {
      "command": "stencil build --docs --prod",
      "dependencies": [
        "build:cem-json",
        "tailwind:build"
      ],
      "files": [
        "src/**/*.{css,scss,ts,tsx}",
        "src/custom-elements.json",
        "!src/components.d.ts",
        "stencil.config.ts",
        "tsconfig.json"
      ],
      "output": [
        "src/components.d.ts",
        "dist/**",
        "loader/**",
        "integrations/react/stencil-generated/**",
        "integrations/angular/ng18/projects/trimble-cms/modus-wc-angular/src/lib/stencil-generated/**",
        "integrations/angular/ng17/projects/trimble-cms/modus-wc-angular/src/lib/stencil-generated/**"
      ]
    },
    "stencil:watch": {
      "command": "stencil build --docs --dev --prod --watch",
      "service": {
        "readyWhen": {
          "lineMatches": "build finished, watching for changes..."
        }
      },
      "dependencies": [
        "build:cem-json",
        "tailwind:watch"
      ],
      "files": [
        "src/**/*.{css,scss,ts,tsx}",
        "src/custom-elements.json",
        "!src/components.d.ts",
        "stencil.config.ts",
        "tsconfig.json"
      ]
    },
    "storybook:build": {
      "command": "storybook build",
      "clean": false,
      "dependencies": [
        "stencil:build"
      ],
      "files": [
        "src/",
        ".storybook",
        "dist/",
        "loader/",
        "stencil.config.ts"
      ],
      "output": [
        "storybook-static/"
      ]
    },
    "storybook:start": {
      "command": "storybook dev -p 6006",
      "dependencies": [
        "stencil:watch"
      ]
    },
    "tailwind:build": {
      "command": "tailwindcss -i src/styles/tailwind.css -o src/styles/output.css --minify",
      "files": [
        "src/**/*.scss",
        "src/styles/tailwind.css",
        "tailwind.config.js"
      ],
      "output": [
        "src/styles/output.css"
      ]
    },
    "tailwind:watch": {
      "command": "tailwindcss -i src/styles/tailwind.css -o src/styles/output.css --minify --watch",
      "service": true,
      "files": [
        "src/**/*.scss",
        "src/styles/tailwind.css",
        "tailwind.config.js"
      ]
    }
  }
}
