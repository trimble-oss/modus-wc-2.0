## Rule 3: Slot Content Testing

Stencil components use `<slot>` for content projection. Slotted content lives in the light DOM.

### Testing Default Slot

```typescript
export const WithSlotContent: Story = {
  render: () => html`
    <modus-wc-button>
      <modus-wc-icon decorative name="notifications"></modus-wc-icon>
      Click me
    </modus-wc-button>
  `,
  play: async ({ canvasElement, step }) => {
    const canvas = within(canvasElement);

    await step('Verify slotted content renders', async () => {
      const button = await canvas.findByRole('button');
      await expect(button).toHaveTextContent('Click me');
    });
  },
};
```

### Testing Named Slots

```typescript
export const WithNamedSlots: Story = {
  render: () => html`
    <modus-wc-card>
      <span slot="header">Card Title</span>
      <p slot="body">Card content here</p>
    </modus-wc-card>
  `,
  play: async ({ canvasElement, step }) => {
    const canvas = within(canvasElement);

    await step('Verify header slot', async () => {
      const header = await canvas.findByText('Card Title');
      await expect(header).toBeInTheDocument();
    });

    await step('Verify body slot', async () => {
      const body = await canvas.findByText('Card content here');
      await expect(body).toBeInTheDocument();
    });
  },
};
```

