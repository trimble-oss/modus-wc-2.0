## Rule 6: Component Composition Testing

Many Modus components are composed of other Modus components (e.g., navbar contains buttons, icons, menus).

```typescript
export const ComposedComponent: Story = {
  render: () => html`
    <modus-wc-navbar>
      <modus-wc-button slot="start">Menu</modus-wc-button>
      <span slot="title">App Title</span>
    </modus-wc-navbar>
  `,
  play: async ({ canvasElement, step }) => {
    const canvas = within(canvasElement);

    await step('Verify composed components render', async () => {
      const button = await canvas.findByRole('button', { name: 'Menu' });
      await expect(button).toBeInTheDocument();

      const title = await canvas.findByText('App Title');
      await expect(title).toBeInTheDocument();
    });
  },
};
```

