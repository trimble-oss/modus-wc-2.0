## File Type Detection for Modus WC 2.0

```typescript
const isComponentFile = (file: string) =>
  file.match(/modus-wc-.*\.tsx$/) && !file.includes('.stories.') && !file.includes('.spec.');

const isStyleFile = (file: string) =>
  file.match(/modus-wc-.*\.scss$/);

const isTestFile = (file: string) =>
  file.includes('.stories.ts') || file.includes('.spec.ts');

const isConfigFile = (file: string) =>
  file.match(/(package\.json|stencil\.config|tsconfig|playwright)/);
```

