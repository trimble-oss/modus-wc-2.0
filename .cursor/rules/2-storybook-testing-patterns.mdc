## Visual State Patterns

### Pattern 11: Prop Coverage

Test all important prop values in separate stories:

```typescript
export const PrimaryButton: Story = {
  render: () => html`<modus-wc-button color="primary">Primary</modus-wc-button>`,
};

export const SecondaryButton: Story = {
  render: () => html`<modus-wc-button color="secondary">Secondary</modus-wc-button>`,
};

export const DisabledButton: Story = {
  render: () => html`<modus-wc-button disabled>Disabled</modus-wc-button>`,
  play: async ({ canvasElement, step }) => {
    const canvas = within(canvasElement);

    await step('Verify button is disabled', async () => {
      const button = await canvas.findByRole('button');
      await expect(button).toBeDisabled();
    });
  },
};
```

### Pattern 12: Interaction Coverage

```typescript
export const AllInteractions: Story = {
  render: () => html`<modus-wc-button>Click me</modus-wc-button>`,
  play: async ({ canvasElement, step }) => {
    const canvas = within(canvasElement);

    await step('Focus', async () => {
      const button = await canvas.findByRole('button');
      button.focus();
      await expect(button).toHaveFocus();
    });

    await step('Click', async () => {
      const button = await canvas.findByRole('button');
      await userEvent.click(button);
    });

    await step('Keyboard Enter', async () => {
      const button = await canvas.findByRole('button');
      button.focus();
      await userEvent.keyboard('{Enter}');
    });

    await step('Keyboard Space', async () => {
      const button = await canvas.findByRole('button');
      button.focus();
      await userEvent.keyboard(' ');
    });
  },
};
```

