## Story Structure (Modus WC 2.0)

### Existing Story Pattern (lit html)

Stories in this project use `lit` html templates with `@storybook/web-components`:

```typescript
import { Meta, StoryObj } from '@storybook/web-components';
import { html } from 'lit';
import { ifDefined } from 'lit/directives/if-defined.js';

interface ComponentArgs {
  prop1: string;
  prop2: boolean;
}

const meta: Meta<ComponentArgs> = {
  title: 'Components/ComponentName',
  component: 'modus-wc-component-name',
  args: {
    prop1: 'default',
    prop2: false,
  },
};

export default meta;
type Story = StoryObj<ComponentArgs>;
```

### Adding Play Functions to Existing Stories

```typescript
import { Meta, StoryObj } from '@storybook/web-components';
import { expect, userEvent, within, fn } from '@storybook/test'; // ADD THIS
import { html } from 'lit';
import { ifDefined } from 'lit/directives/if-defined.js';

// ... existing meta and args ...

export const Default: Story = {
  render: (args) => html`
    <modus-wc-component-name
      prop1="${args.prop1}"
      ?prop2="${args.prop2}"
    >
      Content
    </modus-wc-component-name>
  `,
  play: async ({ canvasElement, step }) => {  // ADD PLAY FUNCTION
    const canvas = within(canvasElement);

    await step('Verify component renders', async () => {
      const element = await canvas.findByRole('button');
      await expect(element).toBeInTheDocument();
    });
  },
};
```

