## Complete Example: Modus WC Button

```typescript
import { Meta, StoryObj } from '@storybook/web-components';
import { expect, userEvent, within } from '@storybook/test';
import { html } from 'lit';

interface ButtonArgs {
  color: 'primary' | 'secondary' | 'tertiary';
  disabled: boolean;
  variant: 'filled' | 'outlined' | 'borderless';
}

const meta: Meta<ButtonArgs> = {
  title: 'Components/Button',
  component: 'modus-wc-button',
  args: {
    color: 'primary',
    disabled: false,
    variant: 'filled',
  },
};

export default meta;
type Story = StoryObj<ButtonArgs>;

export const Default: Story = {
  render: (args) => html`
    <modus-wc-button
      color="${args.color}"
      ?disabled="${args.disabled}"
      variant="${args.variant}"
    >
      Click me
    </modus-wc-button>
  `,
  play: async ({ canvasElement, step }) => {
    const canvas = within(canvasElement);

    await step('Verify button renders', async () => {
      const button = await canvas.findByRole('button');
      await expect(button).toBeInTheDocument();
    });

    await step('Click button', async () => {
      const button = await canvas.findByRole('button');
      let clicked = false;
      button.addEventListener('buttonClick', () => { clicked = true; }, { once: true });
      await userEvent.click(button);
      await expect(clicked).toBe(true);
    });

    await step('Verify keyboard activation', async () => {
      const button = await canvas.findByRole('button');
      button.focus();
      await expect(button).toHaveFocus();
      await userEvent.keyboard('{Enter}');
    });
  },
};

export const Disabled: Story = {
  render: () => html`
    <modus-wc-button disabled>Disabled</modus-wc-button>
  `,
  play: async ({ canvasElement, step }) => {
    const canvas = within(canvasElement);

    await step('Verify button is disabled', async () => {
      const button = await canvas.findByRole('button');
      await expect(button).toBeDisabled();
    });
  },
};
```

